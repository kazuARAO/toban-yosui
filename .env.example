# PostgreSQL
# 本番 (Supabase):
#   DATABASE_URL: Transaction pooler (port 6543, Vercel serverless 用)
#   DIRECT_URL:   Session pooler (port 5432, Prisma migration 用)
# ローカル開発: docker compose の単一 URL を両方に
DATABASE_URL="postgresql://toban:toban@localhost:5444/toban_yosui?schema=public"
DIRECT_URL="postgresql://toban:toban@localhost:5444/toban_yosui?schema=public"

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# scraper user agent (toban-yosui.jp スクレイピング時のマナー)
SCRAPER_USER_AGENT="toban-yosui-watcher/0.1 (+https://github.com/kazuARAO/toban-yosui)"
